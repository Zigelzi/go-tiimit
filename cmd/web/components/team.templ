package components

import "github.com/Zigelzi/go-tiimit/internal/player"

templ team(players []player.Player, teamNumber int) {
	<div class="mb-8">
		<h2 class="font-bold">Team { teamNumber }</h2>
		for _, player := range players {
			if len(players) > 0 {
				<ol>
					<li>{ player.Name } [{ player.Score() }]</li>
				</ol>
			} else {
				<p>No players in team { teamNumber }</p>
			}
		}
	</div>
}
