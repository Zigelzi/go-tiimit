package components

import "github.com/Zigelzi/go-tiimit/cmd/web/view"

templ PracticePage(practice view.Practice) {
	@Base("Practices") {
		<div>
			<div class="mb-4 text-sm">
				<p>Practices on { practice.Date.Weekday() } { practice.Date.Format("02.01.2006") }</p>
			</div>
			@team(practice.Teams[0])
			@team(practice.Teams[1])
		</div>
	}
}
